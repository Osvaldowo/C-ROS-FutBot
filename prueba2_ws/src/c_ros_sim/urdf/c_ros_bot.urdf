<?xml version="1.0"?>
<robot name="c_ros_bot">

  <material name="blue"><color rgba="0 0 0.8 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.017" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://c_ros_sim/meshes/Futbot3.0.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.15 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <origin xyz="-0.005 0.03 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.025"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="-0.005 0.03 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.10 0 0.034" rpy="0 0 1.5708"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="-0.005 -0.03 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.025"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="-0.005 -0.03 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.10 0 0.034" rpy="0 0 1.5708"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <origin xyz="0 -0.035 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </visual>
    <collision><geometry><sphere radius="0.015"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0 0.10 0.015" rpy="0 0 0"/>
  </joint>

  <link name="caster_wheel2">
    <visual>
      <origin xyz="0 -0.165 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </visual>
    <collision><geometry><sphere radius="0.015"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>
  <joint name="caster_wheel2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel2"/>
    <origin xyz="0 0.10 0.015" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link">
    <visual><material><ambient>0 0 0.8 1</ambient><diffuse>0 0 0.8 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="left_wheel">
    <visual><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="right_wheel">
    <visual><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="caster_wheel">
    <mu>0.001</mu><mu2>0.001</mu2>
  </gazebo>
  <gazebo reference="caster_wheel2">
    <mu>0.001</mu><mu2>0.001</mu2>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.20</wheel_separation>
      <wheel_radius>0.034</wheel_radius>
      <max_linear_velocity>0.88</max_linear_velocity>
      <max_angular_velocity>10.6</max_angular_velocity>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>
</robot>